# rec0 — 100% self-contained, zero external API keys required
# No OPENAI_API_KEY needed — embeddings and summaries run locally
DATABASE_URL=postgresql://user:password@host:port/dbname
SECRET_KEY=r0_your_secret_key_here
# Optional: set SECRET_KEY_HASH (bcrypt) for production-grade key security
# Generate with: POST /v1/auth/keygen
# SECRET_KEY_HASH=<bcrypt_hash>
