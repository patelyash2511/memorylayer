# ── rec0 API ──────────────────────────────────────────────────────────────────
# Required: your database connection string
DATABASE_URL=postgresql://user:password@host:port/dbname

# Required: API key accepted by the server (plain-text mode)
SECRET_KEY=your_secret_key_here

# Optional: bcrypt hash of SECRET_KEY (recommended for production)
# Generate with: POST /v1/auth/keygen
SECRET_KEY_HASH=your_bcrypt_hash_here

# Optional: Supabase project credentials (if using Supabase)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# ── rec0 SDK ──────────────────────────────────────────────────────────────────
# Your rec0 API key — auto-loaded by the SDK if api_key= not passed
REC0_API_KEY=r0_your_key_here

# Optional: override the API base URL (useful for self-hosting)
REC0_BASE_URL=https://api.rec0.ai
